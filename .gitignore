# Server directory - published sites (MVP имитация)
server/*/
!server/.gitignore
!server/README.md

.cache
# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Environment / secrets
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Private keys / certificates
id_rsa
id_dsa
id_ecdsa
id_ed25519
id_rsa_*
id_dsa_*
id_ecdsa_*
id_ed25519_*
*.pem
*.p12
*.pfx
*.jks
*.keystore
*.key
!*.pub

# Reserved local ssh key paths for deploy integrations
secrets/ssh/*
!secrets/ssh/.gitkeep
!secrets/ssh/README.md

# Build
dist/
build/

# Frontend
node_modules
.next

# Generated seed file
pbn-generator/init/seed.sql

# Local PostgreSQL bind-mount storage (docker compose)
data/postgres/*
!data/postgres/.gitkeep

# Local PostgreSQL backups
backups/postgres/*
!backups/postgres/.gitkeep
!backups/postgres/container/
backups/postgres/container/*
!backups/postgres/container/.gitkeep
