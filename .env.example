# Production template (fill with real values via secrets manager/CI).

GEMINI_API_KEY=

DB_DRIVER=pgx
DB_DSN=postgres://app_user:change_me_db_password@db:5432/app_db?sslmode=disable
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=app_db

PORT=8080
ALLOWED_ORIGINS=https://app.example.com
PUBLIC_APP_URL=https://app.example.com

SESSION_TTL=24h
SESSION_CLEAN_INTERVAL=5m
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_TTL=14d
JWT_SECRET=change_me_jwt_secret_at_least_12_chars
JWT_ISSUER=authserver
COOKIE_DOMAIN=.example.com
COOKIE_SECURE=true

LOGIN_RATE_LIMIT=30
LOGIN_RATE_WINDOW=1m
LOGIN_EMAIL_IP_LIMIT=10
LOGIN_EMAIL_IP_WINDOW=1m
REGISTER_RATE_LIMIT=10
REGISTER_RATE_WINDOW=1m
LOGIN_LOCKOUT_FAILS=5
LOGIN_LOCKOUT_DURATION=15m

CAPTCHA_PROVIDER=internal
CAPTCHA_SECRET=
CAPTCHA_REQUIRED=true
CAPTCHA_REQUIRED_REGISTER=true
CAPTCHA_REQUIRED_LOGIN=true
CAPTCHA_REQUIRED_RESET=true
CAPTCHA_REQUIRED_VERIFY=false

PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

REQUIRE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_TTL=24h
PASSWORD_RESET_TTL=1h

BOOTSTRAP_ADMIN_EMAIL=
AUTO_APPROVE_USERS=false

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASSWORD=change_me_smtp_password
SMTP_SENDER=no-reply@example.com
SMTP_USE_TLS=true

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana_admin_password
API_KEY_SECRET=change_me_api_key_secret_min_32_chars

# Keep local_mock globally; enable ssh_remote per-domain first (canary rollout).
DEPLOY_MODE=local_mock
DEPLOY_TIMEOUT=30s
DEPLOY_MAX_PARALLEL=5
DEPLOY_STAGING_STRATEGY=co_located
DEPLOY_STAGING_DIR_NAME=.tmp_deploy
DEPLOY_TARGETS_JSON=
DEPLOY_KNOWN_HOSTS_PATH=./secrets/ssh/known_hosts
DEPLOY_SSH_POOL_MAX_OPEN=5
DEPLOY_SSH_POOL_MAX_IDLE=2
DEPLOY_SSH_POOL_IDLE_TTL=60s
DEPLOY_SSH_KEY_PATH=

NEXT_PUBLIC_REFRESH_INTERVAL_MS=600000
NEXT_PUBLIC_REFRESH_ON_ACTIVITY_MS=300000
SERP_TIMEOUT_SECONDS=45
SERP_RETRIES=0
GEN_TRANSITION_STALE_AFTER=2m


FILE_REVISION_MAX_PER_FILE=10